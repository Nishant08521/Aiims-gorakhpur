      <img src="assets/images/aiims/Dr._Goverdhan_Dutt_Puri.png" class="img-fluid mx-auto d-block" alt="minister-of-state-MohFW" style="width: 30%; box-shadow: none; border-radius: 0;">
      <div class="card-body">
