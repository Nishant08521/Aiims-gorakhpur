<div class="container card-group text-dark">
    <div class="card text-center" style="border: none; background-color: transparent;">
      <img src="assets/images/aiims/tejas_madhusudan_patel_president.png" class="img-fluid mx-auto d-block" alt="Union-Minister-MohFW" style="width: 30%; box-shadow: none; border-radius: 0;">
      <div class="card-body">
        <h5 class="card-title">Prof. (Dr.) Tejas Madhusudan Patel</h5>
        <p class="card-text">President - Institute</p>
