    crossorigin="anonymous" referrerpolicy="no-referrer" />

  <!-- Suppress browser extension errors ASAP -->
  <script>
    (function () {
      // Suppress unhandled promise rejections from browser extensions
      window.addEventListener('unhandledrejection', function (event) {
        var error = event.reason;
        if (error) {
          try {
            var errorStr = JSON.stringify(error);
            // Check for extension error patterns
            if (
              (error.name === 'i') ||
              (error.code === 403 && error.httpStatus === 200) ||
              (errorStr.indexOf('"name":"i"') !== -1) ||
              (errorStr.indexOf('"code":403') !== -1 && errorStr.indexOf('"httpStatus":200') !== -1) ||
              (errorStr.indexOf('httpError') !== -1)
            ) {
              event.stopImmediatePropagation();
              event.preventDefault();
              return false;
            }
          } catch (e) { }
        }
      }, true);

      // Suppress error events from extensions
      window.addEventListener('error', function (event) {
        if (event.filename && (
          event.filename.indexOf('content.js') !== -1 ||
          event.filename.indexOf('chrome-extension') !== -1 ||
          event.filename.indexOf('moz-extension') !== -1 ||
          event.filename.indexOf('extension') !== -1
        )) {
          event.stopImmediatePropagation();
          event.preventDefault();
          return false;
        }
      }, true);
    })();
  </script>
